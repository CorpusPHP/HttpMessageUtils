{
	"name": "corpus/http-message-utils",
	"description": "Utilities for working with Psr7 Http Messages",
	"type": "library",
	"require": {
		"psr/http-message": "^1.1 || ^2.0",
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"php-mock/php-mock-phpunit": "^2.15",
		"guzzlehttp/psr7": "^2.12",
		"corpus/coding-standard": "^0.10.0",
		"squizlabs/php_codesniffer": "^4.0",
		"friendsofphp/php-cs-fixer": "^3.95",
		"donatj/mddoc": "^0.10.1",
		"donatj/drop": "^1.1",
		"phpstan/phpstan": "^2.2"
	},
	"license": "MIT",
	"authors": [
		{
			"name": "Jesse Donat",
			"email": "donatj@gmail.com"
		}
	],
	"autoload": {
		"psr-4": {
			"Corpus\\HttpMessageUtils\\": "src/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
